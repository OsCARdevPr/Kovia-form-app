# ════════════════════════════════════════════════════════════
# Kovia — Variables de entorno (Dokploy / Producción)
# Copia este archivo a .env solo para pruebas locales.
# En Dokploy, carga estos valores desde el panel de variables.
# ════════════════════════════════════════════════════════════

# ── Entorno ────────────────────────────────────────────────
NODE_ENV=production

# ── Base de datos externa gestionada ────────────────────────
DB_HOST=postgres.tu-proveedor.internal
DB_PORT=5432
DB_NAME=kovia_db
DB_USER=kovia_admin
DB_PASSWORD=REEMPLAZAR_EN_DOKPLOY
DB_DIALECT=postgres

# ── Seguridad API ───────────────────────────────────────────
JWT_SECRET=REEMPLAZAR_EN_DOKPLOY
AUTH_COOKIE_NAME=kovia_admin_token
AUTH_TOKEN_TTL_HOURS=12

# Orígenes permitidos por CORS (subdominios públicos)
CORS_ORIGIN=https://form.tu-dominio.com,https://admin.tu-dominio.com

# ── Frontend Form (Astro) ──────────────────────────────────
# URL pública de la API consumida por el navegador.
# Esta variable se embebe en build-time.
PUBLIC_API_URL=https://api.tu-dominio.com

# ── Frontend Admin (Vite) ──────────────────────────────────
# Estas variables se embeben en build-time.
VITE_ADMIN_API_URL=https://api.tu-dominio.com
VITE_FORM_URL_BASE=https://form.tu-dominio.com
