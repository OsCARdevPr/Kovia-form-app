# ══════════════════════════════════════════
# KOVIA API — Environment Variables
# Copia este archivo como .env y completa tus credenciales
# ══════════════════════════════════════════

# Puerto del servidor
PORT=3001

# Base de datos (MySQL o PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kovia_db
DB_USER=root
DB_PASSWORD=yourpassword
DB_DIALECT=postgres

# CORS — URLs permitidas separadas por coma
CORS_ORIGIN=http://localhost:4321,http://localhost:5174

# Entorno
NODE_ENV=development

# JWT + cookies
JWT_SECRET=change-me-super-secret
AUTH_COOKIE_NAME=kovia_admin_token
AUTH_TOKEN_TTL_HOURS=12

# Usuario admin inicial (opcional en producción)
ADMIN_NAME=Admin Kovia
ADMIN_EMAIL=admin@kovia.local
ADMIN_PASSWORD=Admin12345!
