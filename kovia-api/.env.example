# ══════════════════════════════════════════
# KOVIA API — Environment Variables
# Copia este archivo como .env y completa tus credenciales
# ══════════════════════════════════════════

# Puerto del servidor
PORT=3001

# Base de datos (MySQL o PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kovia_db
DB_USER=root
DB_PASSWORD=yourpassword
DB_DIALECT=postgres

# CORS — URL del frontend Astro (en producción cambia esto)
CORS_ORIGIN=http://localhost:4321
