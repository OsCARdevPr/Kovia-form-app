  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Isla React: renderiza canvas + formulario directamente en el árbol React -->
  <DiscoveryApp client:load />
