---
import DiscoveryApp from '../components/DiscoveryApp';
import '../styles/global.css';

const rawSlug = String(Astro.params.slug || '').trim();
const formSlug = rawSlug ? decodeURIComponent(rawSlug) : '';
const pageTitleSlug = formSlug || 'formulario';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kovia Form | {pageTitleSlug}</title>
  <meta name="description" content="Formulario dinámico de Kovia cargado por slug en la URL." />
  <meta name="theme-color" content="#090a0e" />
  <link rel="icon" type="image/png" href="/kovia-ghost.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Orbitron:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <DiscoveryApp client:load formSlug={formSlug} />
</body>
</html>